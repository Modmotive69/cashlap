# ============================================================
# CashLap — Environment Variables
# Copy this file to .env and fill in your values.
# cp .env.example .env
# ============================================================

# ── Required ─────────────────────────────────────────────────

# Base44 App ID (from your Base44 dashboard → Settings → App ID)
VITE_BASE44_APP_ID=your_base44_app_id_here

# Enable Base44 legacy SDK imports at build time (required for entities/integrations)
BASE44_LEGACY_SDK_IMPORTS=true

# ── Monitoring (optional but strongly recommended for production) ─

# Sentry DSN for error monitoring (https://sentry.io → New Project → DSN)
# Leave blank to disable Sentry (no-op in local dev)
VITE_SENTRY_DSN=

# App version tag shown in Sentry releases
VITE_APP_VERSION=1.0.0

# ── Analytics (optional but strongly recommended) ─────────────

# PostHog project API key (https://posthog.com → Project Settings → API Key)
# Leave blank to disable PostHog (no-op in local dev)
VITE_POSTHOG_KEY=

# PostHog host — use default unless self-hosting
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Developer Tools ──────────────────────────────────────────

# Set to 'true' to enable the Base44 visual edit agent (dev only — never in production)
VITE_ENABLE_VISUAL_EDIT=false

# ── Backend Proxy (optional — for local development against custom backend) ─

# Base44 backend URL — enables /api proxy in local dev server
# Leave blank to use default Base44 cloud backend
# VITE_BASE44_BACKEND_URL=https://api.base44.com

# ── Notes ────────────────────────────────────────────────────
# Stripe keys, TikTok OAuth credentials, and Mapbox tokens are
# configured server-side inside Base44 as environment variables.
# They are NOT stored in this repo.
#
# For Supabase migration: see docs/SUPABASE_MIGRATION.md
